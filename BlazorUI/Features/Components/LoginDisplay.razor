<AuthorizeView>
    <Authorized>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mr-2">
            <MudButton Href="/authentication/editprofile"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Rounded.Person"
                       Class="text-none">
                @context.User.Claims.FirstOrDefault(c => c.Type.Contains("givenname", StringComparison.OrdinalIgnoreCase))?.Value
            </MudButton>
            <MudButton Href="/authentication/logout"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Rounded.Logout"
                       Class="text-none">
                Logout
            </MudButton>
        </MudStack>
    </Authorized>
    <NotAuthorized>
        <MudButton Href="/authentication/login"
                   Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Rounded.Login"
                   Class="mr-2 text-none">
            Login
        </MudButton>
    </NotAuthorized>
</AuthorizeView>
